# --- Data source -----------------------------------------------------------
# "mock"   -> fully in-memory, no backend, no crypto. Default for contributors.
# "rest"   -> read Plaid-fed accounts/transactions from the shared ConjureOS
#             Supabase project via PostgREST. Writes column-scoped mutations
#             back (transactions.user_category + budgets full CRUD).
# "synced" -> legacy end-to-end encrypted prototype (kept for the manual-entry
#             mode story; finance moved to server-side encryption at rest,
#             see DECISIONS.md 2026-05-28).
VITE_FINANCE_API=mock

# --- Backend (used by "rest" and "synced") ---------------------------------
# Supabase project root URL (no trailing path). Used by RestFinanceApi for
# PostgREST + by the Plaid lifecycle helpers (link/exchange/sync/unlink).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Project anon key (publishable). RLS enforces per-user scoping.
VITE_SUPABASE_ANON_KEY=your-anon-key

# Edge Functions base URL. Defaults to {VITE_SUPABASE_URL}/functions/v1 if you
# leave this blank; override only if you point at a non-standard host.
VITE_SUPABASE_FUNCTIONS_URL=

# Legacy alias kept for the "synced" mode's HttpSyncTransport. Point this at
# the edge functions root if you still need the encrypted-sync prototype.
VITE_SYNC_BASE_URL=

# --- Categorization orchestrator -------------------------------------------
# Inference routing for client-side categorization. Plaintext never leaves the
# browser except (optionally) to the model provider you choose here.
# "heuristic" -> rules-only, no network, no key needed. Always available.
# "anthropic" -> use an Anthropic model. Key resolved tier -> group -> BYK.
VITE_INFERENCE_PROVIDER=heuristic

# Bring-your-own-key (BYK) fallback for the anthropic provider.
# Leave blank to rely on tier/group credits supplied by ConjureOS at runtime.
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
