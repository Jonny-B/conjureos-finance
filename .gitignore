# claude code worktree-local state — most of .claude/ is per-developer
# (worktrees, local settings, CLI caches inside worktree paths). Shared
# hooks + the committed settings.json (for SessionStart, etc.) are
# explicitly allowed back in; .claude/settings.local.json stays ignored.
.claude/*
!.claude/hooks/
!.claude/settings.json
.claude/settings.local.json
