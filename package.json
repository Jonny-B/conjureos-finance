{
  "name": "conjureos-finance",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Privacy-first personal finance app (Mint/Rocket Money clone) for ConjureOS. End-to-end encrypted; the server never sees your transactions.",
  "conjureos": {
    "displayName": "Conjure Finance",
    "icon": "💰",
    "permissions": [
      "ai.complete",
      "vfs.read",
      "vfs.write"
    ],
    "promptSuggestions": [
      "Categorize my recent transactions",
      "How much did I spend on groceries this month?",
      "Show my spending by category"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:inline": "tsc -b && vite build --mode inline",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@conjureos/ui": "^0.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.8"
  }
}
